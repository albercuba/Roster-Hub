APP_NAME=Roster Hub
APP_ENV=development
PUBLIC_URL=http://localhost:8084
DATABASE_URL=postgresql+psycopg://rosterhub:rosterhub@roster-hub-db:5432/rosterhub
SECRET_KEY=change-me
SESSION_COOKIE_NAME=roster_hub_session
SESSION_SECURE=false
SESSION_TTL_HOURS=12
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
DEFAULT_LANGUAGE=EN
LANGUAGE_STORAGE_DIR=/var/lib/roster-hub/languages
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Roster Hub
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SECURITY_HEADERS_ENABLED=true
